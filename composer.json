{
    "name": "taxpilot/taxpilot",
    "description": "Polish investment tax calculator — PIT-38 for foreign brokers",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.4",
        "brick/math": "^0.12",
        "doctrine/doctrine-bundle": "^2.0",
        "doctrine/doctrine-migrations-bundle": "^3.0",
        "doctrine/orm": "^3.0",
        "dompdf/dompdf": "^3.1",
        "league/flysystem-bundle": "^3.0",
        "stripe/stripe-php": "^20.0",
        "symfony/asset": "^8.0",
        "symfony/asset-mapper": "^7.2",
        "symfony/cache": "^7.2",
        "symfony/framework-bundle": "^7.2",
        "symfony/http-client": "^7.2",
        "symfony/mailer": "^7.2",
        "symfony/messenger": "^7.2",
        "symfony/rate-limiter": "^8.0",
        "symfony/redis-messenger": "^8.0",
        "symfony/runtime": "^7.2",
        "symfony/security-bundle": "^7.2",
        "symfony/serializer": "^7.2",
        "symfony/stimulus-bundle": "^2.0",
        "symfony/twig-bundle": "^7.2",
        "symfony/uid": "^7.2",
        "symfony/ux-turbo": "^2.0",
        "symfony/validator": "^7.2",
        "symfony/var-exporter": "^7.2",
        "symfony/yaml": "^7.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "infection/infection": "^0.29",
        "pact-foundation/pact-php": "^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0",
        "qossmic/deptrac": "^2.0",
        "rector/rector": "^2.0",
        "symfony/browser-kit": "^8.0",
        "symfony/css-selector": "^8.0",
        "symfony/debug-bundle": "^7.2",
        "symfony/dotenv": "^7.2",
        "symfony/maker-bundle": "^1.0",
        "symfony/web-profiler-bundle": "^7.2",
        "symplify/easy-coding-standard": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "infection/extension-installer": true,
            "symfony/flex": true,
            "pact-foundation/composer-downloads-plugin": true
        },
        "sort-packages": true
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.2.*"
        }
    }
}
