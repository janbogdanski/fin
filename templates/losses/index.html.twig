{% extends 'base.html.twig' %}

{% block title %}Straty z lat ubieglych - TaxPilot{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">Straty z lat ubieglych</h1>
    <p class="text-gray-600 mb-8">
        Wprowadz straty z poprzednich lat podatkowych do odliczenia od dochodu (art. 9 ust. 3 ustawy o PIT).
        Strate mozna odliczyc w ciagu 5 kolejnych lat, max 50% kwoty rocznie.
    </p>

    {# Add loss form #}
    <div class="bg-white rounded-lg border border-gray-200 p-6 mb-8">
        <h2 class="text-sm font-semibold text-gray-900 mb-4">Dodaj strate</h2>

        <form action="{{ path('losses_store') }}" method="post">
            <input type="hidden" name="_token" value="{{ csrf_token('losses_store') }}">

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
                <div>
                    <label for="loss_year" class="block text-sm font-medium text-gray-700 mb-1">Rok straty</label>
                    <select name="loss_year" id="loss_year"
                            class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                        {% for year in maxLossYear..minLossYear %}
                            <option value="{{ year }}">{{ year }}</option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label for="tax_category" class="block text-sm font-medium text-gray-700 mb-1">Kategoria</label>
                    <select name="tax_category" id="tax_category"
                            class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                        {% for cat in taxCategories %}
                            <option value="{{ cat.value }}">
                                {% if cat.value == 'EQUITY' %}Akcje / ETF
                                {% elseif cat.value == 'DERIVATIVE' %}Instrumenty pochodne
                                {% elseif cat.value == 'CRYPTO' %}Kryptowaluty
                                {% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>

                <div>
                    <label for="amount" class="block text-sm font-medium text-gray-700 mb-1">Kwota straty (PLN)</label>
                    <input type="text" name="amount" id="amount"
                           placeholder="np. 10000.00"
                           inputmode="decimal"
                           class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500">
                </div>
            </div>

            <button type="submit"
                    class="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
                Dodaj strate
            </button>
        </form>
    </div>

    {# Existing losses #}
    {% if losses is not empty %}
    <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-200">
            <h2 class="text-sm font-semibold text-gray-900">Zapisane straty</h2>
        </div>
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Rok</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kategoria</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Kwota oryginalna</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Pozostalo</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-3"></th>
                </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
                {% for loss in losses %}
                <tr>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ loss.loss_year }}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                        {% if loss.tax_category == 'EQUITY' %}Akcje / ETF
                        {% elseif loss.tax_category == 'DERIVATIVE' %}Instrumenty pochodne
                        {% elseif loss.tax_category == 'CRYPTO' %}Kryptowaluty
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                        {{ loss.original_amount|number_format(2, ',', ' ') }} PLN
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
                        {{ loss.remaining_amount|number_format(2, ',', ' ') }} PLN
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right">
                        {% set expiresYear = loss.loss_year + 5 %}
                        {% if expiresYear < currentYear %}
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">Wygasla</span>
                        {% elseif expiresYear == currentYear %}
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">Ostatni rok</span>
                        {% else %}
                            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">Do {{ expiresYear }}</span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-right text-sm">
                        <form action="{{ path('losses_delete', {id: loss.id}) }}" method="post" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('losses_delete_' ~ loss.id) }}">
                            <button type="submit"
                                    class="text-red-600 hover:text-red-800 text-xs font-medium"
                                    onclick="return confirm('Czy na pewno chcesz usunac te strate?')">
                                Usun
                            </button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% else %}
    <div class="bg-white rounded-lg border border-gray-200 p-6 text-center">
        <p class="text-sm text-gray-500">Brak zapisanych strat z lat ubieglych.</p>
        <p class="text-xs text-gray-400 mt-1">Dodaj straty powyzej, aby zostaly uwzglednione w obliczeniu podatku.</p>
    </div>
    {% endif %}

    {# Info box #}
    <div class="mt-8 bg-blue-50 rounded-lg border border-blue-200 p-5">
        <h3 class="text-sm font-semibold text-blue-900 mb-2">Zasady odliczania strat</h3>
        <ul class="text-sm text-blue-800 space-y-1 list-disc list-inside">
            <li>Strate mozna odliczac przez 5 kolejnych lat podatkowych (art. 9 ust. 3 ustawy o PIT).</li>
            <li>W jednym roku mozna odliczyc maksymalnie 50% kwoty straty.</li>
            <li>Kryptowaluty maja osobny koszyk strat (art. 30b ust. 5a-5g).</li>
            <li>Straty z akcji/ETF i instrumentow pochodnych lacza sie w jeden koszyk.</li>
        </ul>
    </div>
</div>
{% endblock %}
