<!DOCTYPE html>
<html lang="pl" class="h-full bg-gray-50">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}TaxPilot{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}TaxPilot — automatyczne rozliczenie PIT-38 z zagranicznych brokerow.{% endblock %}">
    <meta name="robots" content="{% block robots %}noindex, nofollow{% endblock %}">
    <link rel="canonical" href="{% block canonical %}{{ app.request.uri }}{% endblock %}">

    {# Open Graph #}
    <meta property="og:type" content="website">
    <meta property="og:title" content="{% block og_title %}{{ block('title') }}{% endblock %}">
    <meta property="og:description" content="{% block og_description %}{{ block('meta_description') }}{% endblock %}">
    <meta property="og:url" content="{% block og_url %}{{ app.request.uri }}{% endblock %}">
    <meta property="og:image" content="{% block og_image %}{{ absolute_url(asset('assets/images/og-default.png')) }}{% endblock %}">
    <meta property="og:locale" content="pl_PL">
    <meta property="og:site_name" content="TaxPilot">

    <link rel="stylesheet" href="{{ asset('assets/styles/app.css') }}">
    {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% block head %}{% endblock %}
</head>
<body class="h-full">
    <nav class="bg-white shadow-sm border-b border-gray-200" role="navigation" aria-label="Nawigacja glowna">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-14 items-center">
                <div class="flex items-center gap-6">
                    <a href="{{ path('dashboard_index') }}" class="text-lg font-semibold text-gray-900 tracking-tight">
                        TaxPilot
                    </a>
                    <div class="hidden sm:flex items-center gap-1">
                        {% set current_route = app.request.attributes.get('_route') %}
                        <a href="{{ path('dashboard_index') }}"
                           class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors {{ current_route starts with 'dashboard' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50' }}"
                           {{ current_route starts with 'dashboard' ? 'aria-current="page"' : '' }}>
                            Dashboard
                        </a>
                        <a href="{{ path('import_index') }}"
                           class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors {{ current_route starts with 'import' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50' }}"
                           {{ current_route starts with 'import' ? 'aria-current="page"' : '' }}>
                            Import CSV
                        </a>
                        <a href="{{ path('declaration_preview', {taxYear: default_tax_year()}) }}"
                           class="px-3 py-1.5 rounded-md text-sm font-medium transition-colors {{ current_route starts with 'declaration' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:text-gray-900 hover:bg-gray-50' }}"
                           {{ current_route starts with 'declaration' ? 'aria-current="page"' : '' }}>
                            PIT-38
                        </a>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    {% if app.user %}
                        {% set tier_label = user_subscription_label() %}
                        {% if tier_label != 'Free' %}
                            <span class="hidden sm:inline-flex items-center px-2 py-0.5 rounded text-xs font-medium {{ tier_label == 'Pro' ? 'bg-purple-100 text-purple-800' : 'bg-blue-100 text-blue-800' }}">
                                {{ tier_label }}
                            </span>
                        {% endif %}
                        <a href="{{ path('profile_edit') }}"
                           class="text-xs text-gray-500 hover:text-gray-700 hidden sm:inline font-medium">Profil</a>
                        <a href="{{ path('profile_edit') }}"
                           class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-gray-200 text-xs font-medium text-gray-600 hover:bg-gray-300 transition-colors"
                           aria-label="Profil uzytkownika">
                            {{ app.user.initials }}
                        </a>
                    {% else %}
                        <a href="{{ path('auth_login') }}"
                           class="text-sm text-blue-600 hover:text-blue-800 font-medium">Zaloguj sie</a>
                    {% endif %}
                </div>
            </div>
            {# Mobile nav #}
            <div class="flex sm:hidden gap-1 pb-2 -mt-1 overflow-x-auto">
                {% set current_route = app.request.attributes.get('_route') %}
                <a href="{{ path('dashboard_index') }}"
                   class="px-3 py-1.5 rounded-md text-xs font-medium whitespace-nowrap transition-colors {{ current_route starts with 'dashboard' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:bg-gray-50' }}"
                   {{ current_route starts with 'dashboard' ? 'aria-current="page"' : '' }}>
                    Dashboard
                </a>
                <a href="{{ path('import_index') }}"
                   class="px-3 py-1.5 rounded-md text-xs font-medium whitespace-nowrap transition-colors {{ current_route starts with 'import' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:bg-gray-50' }}"
                   {{ current_route starts with 'import' ? 'aria-current="page"' : '' }}>
                    Import CSV
                </a>
                <a href="{{ path('declaration_preview', {taxYear: default_tax_year()}) }}"
                   class="px-3 py-1.5 rounded-md text-xs font-medium whitespace-nowrap transition-colors {{ current_route starts with 'declaration' ? 'bg-gray-100 text-gray-900' : 'text-gray-600 hover:bg-gray-50' }}"
                   {{ current_route starts with 'declaration' ? 'aria-current="page"' : '' }}>
                    PIT-38
                </a>
            </div>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        {% for type in ['error', 'warning', 'success', 'info'] %}
            {% for message in app.flashes(type) %}
                {% set flashClasses = {
                    'error': 'bg-red-50 text-red-800 border border-red-200',
                    'warning': 'bg-amber-50 text-amber-800 border border-amber-200',
                    'success': 'bg-green-50 text-green-800 border border-green-200',
                    'info': 'bg-blue-50 text-blue-800 border border-blue-200',
                } %}
                <div class="mb-4 rounded-md p-4 {{ flashClasses[type] }}" role="alert">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {% block body %}{% endblock %}
    </main>

    <footer class="mt-auto border-t border-gray-200 py-6">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <p class="text-center text-xs text-gray-400">
                TaxPilot &mdash; narzedzie pomocnicze do rozliczania PIT-38.
                Nie stanowi doradztwa podatkowego.
            </p>
        </div>
    </footer>

    {% block structured_data %}{% endblock %}
</body>
</html>
