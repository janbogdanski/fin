{% extends 'base.html.twig' %}

{% block title %}PIT/ZG {{ country.countryCode }} {{ taxYear }} - TaxPilot{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('dashboard_dividends', {taxYear: taxYear}) }}" class="text-sm text-blue-600 hover:text-blue-800 font-medium">&larr; Dywidendy wg kraju</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-1">PIT/ZG &mdash; {{ country.countryCode }}</h1>
        <p class="text-sm text-gray-600 mt-1">Zalacznik do PIT-38 za rok {{ taxYear }} &mdash; dochody z kraju {{ country.countryCode }}.</p>
    </div>

    <section class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
        <div class="bg-gray-50 px-5 py-3 border-b border-gray-200">
            <h2 class="text-sm font-semibold text-gray-900">
                PIT/ZG &mdash; Informacja o wysokosci dochodow z zagranicy
            </h2>
        </div>
        <div class="p-5">
            <dl class="space-y-3">
                <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                    <dt class="text-sm text-gray-600">Kraj</dt>
                    <dd class="text-sm font-medium text-gray-900 text-right">
                        <span class="inline-flex items-center gap-2">
                            <span class="inline-flex items-center justify-center w-7 h-5 rounded-sm bg-gray-100 text-xs font-bold text-gray-600 border border-gray-200">
                                {{ country.countryCode }}
                            </span>
                            {{ country.countryCode }}
                        </span>
                    </dd>
                </div>
                <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                    <dt class="text-sm text-gray-600">Dochod brutto (PLN)</dt>
                    <dd class="text-sm font-mono font-medium text-gray-900 text-right">{{ country.grossDividendPLN|number_format(2, ',', ' ') }}</dd>
                </div>
                <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                    <dt class="text-sm text-gray-600">Podatek zaplacony za granica (WHT)</dt>
                    <dd class="text-sm font-mono font-medium text-gray-900 text-right">{{ country.whtPaidPLN|number_format(2, ',', ' ') }}</dd>
                </div>
                <div class="grid grid-cols-2 gap-4 items-center py-2 bg-blue-50 -mx-5 px-5 rounded">
                    <dt class="text-sm font-semibold text-blue-800">Doplata podatku w PL</dt>
                    <dd class="text-sm font-mono font-bold {{ country.polishTaxDue > 0 ? 'text-red-600' : 'text-green-600' }} text-right">
                        {{ country.polishTaxDue|number_format(2, ',', ' ') }} PLN
                    </dd>
                </div>
            </dl>
        </div>
    </section>

    <div class="mt-6 flex gap-3">
        <a href="{{ path('dashboard_dividends', {taxYear: taxYear}) }}"
           class="inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
            &larr; Wstecz
        </a>
        <a href="{{ path('declaration_preview', {taxYear: taxYear}) }}"
           class="inline-flex items-center gap-2 rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 transition-colors">
            Podglad PIT-38
        </a>
    </div>

    {% include 'declaration/_disclaimer.html.twig' %}
</div>
{% endblock %}
