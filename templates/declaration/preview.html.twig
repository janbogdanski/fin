{% extends 'base.html.twig' %}

{% block title %}PIT-38 Podglad {{ pit38.taxYear }} - TaxPilot{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto">
    <div class="mb-6">
        <a href="{{ path('dashboard_index') }}" class="text-sm text-blue-600 hover:text-blue-800 font-medium">&larr; Dashboard</a>
        <h1 class="text-2xl font-bold text-gray-900 mt-1">PIT-38 &mdash; Podglad deklaracji {{ pit38.taxYear }}</h1>
        <p class="text-sm text-gray-600 mt-1">
            {% if pit38.firstName and pit38.lastName %}
                {{ pit38.firstName }} {{ pit38.lastName }}
            {% else %}
                <span class="text-amber-600 font-medium">[dane osobowe nie uzupelnione]</span>
            {% endif %}
            &middot; NIP:
            {% if pit38.nip %}
                {{ pit38.nip[:3] }}*****{{ pit38.nip[-2:] }}
            {% else %}
                <span class="text-amber-600 font-medium">[nie uzupelniony]</span>
            {% endif %}
            {% if pit38.isCorrection %}
                <span class="ml-2 inline-block px-2 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-800">Korekta</span>
            {% endif %}
        </p>
        {% if not pit38.hasCompletePersonalData %}
            <div class="mt-3 rounded-md bg-amber-50 border border-amber-200 p-3">
                <p class="text-sm text-amber-800">
                    Uzupelnij swoj NIP i dane osobowe w
                    <a href="{{ path('profile_edit') }}" class="font-medium underline hover:text-amber-900">profilu</a>,
                    aby wygenerowac PIT-38.
                </p>
            </div>
        {% endif %}
    </div>

    {# PIT-38 form visualization #}
    <div class="space-y-6">

        {# Section C — Equity #}
        <section class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
            <div class="bg-gray-50 px-5 py-3 border-b border-gray-200">
                <h2 class="text-sm font-semibold text-gray-900">Sekcja C &mdash; Odplatne zbycie papierow wartosciowych</h2>
            </div>
            <div class="p-5">
                <dl class="space-y-3">
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">C.1 Przychod ze sprzedazy</dt>
                        <dd class="text-sm font-mono font-medium text-gray-900 text-right">{{ pit38.equityProceeds|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">C.2 Koszty uzyskania przychodu</dt>
                        <dd class="text-sm font-mono font-medium text-gray-900 text-right">{{ pit38.equityCosts|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">C.3 Dochod (przychod - koszty)</dt>
                        <dd class="text-sm font-mono font-medium {{ pit38.equityIncome > 0 ? 'text-green-600' : 'text-gray-900' }} text-right">
                            {{ pit38.equityIncome|number_format(2, ',', ' ') }} PLN
                        </dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">C.4 Strata</dt>
                        <dd class="text-sm font-mono font-medium {{ pit38.equityLoss > 0 ? 'text-red-600' : 'text-gray-900' }} text-right">
                            {{ pit38.equityLoss|number_format(2, ',', ' ') }} PLN
                        </dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">C.5 Podstawa opodatkowania</dt>
                        <dd class="text-sm font-mono font-medium text-gray-900 text-right">{{ pit38.equityTaxBase|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 bg-blue-50 -mx-5 px-5 rounded">
                        <dt class="text-sm font-semibold text-blue-800">C.6 Podatek (19%)</dt>
                        <dd class="text-sm font-mono font-bold text-blue-800 text-right">{{ pit38.equityTax|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                </dl>
            </div>
        </section>

        {# Section D — Dividends #}
        <section class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
            <div class="bg-gray-50 px-5 py-3 border-b border-gray-200">
                <h2 class="text-sm font-semibold text-gray-900">Sekcja D &mdash; Dywidendy zagraniczne</h2>
            </div>
            <div class="p-5">
                <dl class="space-y-3">
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">D.1 Dywidendy brutto</dt>
                        <dd class="text-sm font-mono font-medium text-gray-900 text-right">{{ pit38.dividendGross|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">D.2 WHT zaplacony za granica</dt>
                        <dd class="text-sm font-mono font-medium text-gray-900 text-right">{{ pit38.dividendWHT|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 bg-blue-50 -mx-5 px-5 rounded">
                        <dt class="text-sm font-semibold text-blue-800">D.3 Doplata podatku PL</dt>
                        <dd class="text-sm font-mono font-bold text-blue-800 text-right">{{ pit38.dividendTaxDue|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                </dl>
                <p class="text-xs text-gray-500 mt-3">
                    Szczegoly per kraj &rarr;
                    <a href="{{ path('dashboard_dividends', {taxYear: pit38.taxYear}) }}" class="text-blue-600 hover:text-blue-800 font-medium">Dywidendy wg kraju</a>
                </p>
            </div>
        </section>

        {# Crypto section #}
        <section class="bg-white rounded-lg border border-gray-200 shadow-sm overflow-hidden">
            <div class="bg-gray-50 px-5 py-3 border-b border-gray-200">
                <h2 class="text-sm font-semibold text-gray-900">Kryptowaluty</h2>
            </div>
            <div class="p-5">
                <dl class="space-y-3">
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">Przychod</dt>
                        <dd class="text-sm font-mono font-medium text-gray-900 text-right">{{ pit38.cryptoProceeds|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">Koszty</dt>
                        <dd class="text-sm font-mono font-medium text-gray-900 text-right">{{ pit38.cryptoCosts|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">Dochod</dt>
                        <dd class="text-sm font-mono font-medium {{ pit38.cryptoIncome > 0 ? 'text-green-600' : 'text-gray-900' }} text-right">
                            {{ pit38.cryptoIncome|number_format(2, ',', ' ') }} PLN
                        </dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 border-b border-gray-100">
                        <dt class="text-sm text-gray-600">Strata</dt>
                        <dd class="text-sm font-mono font-medium text-gray-900 text-right">{{ pit38.cryptoLoss|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                    <div class="grid grid-cols-2 gap-4 items-center py-2 bg-blue-50 -mx-5 px-5 rounded">
                        <dt class="text-sm font-semibold text-blue-800">Podatek (19%)</dt>
                        <dd class="text-sm font-mono font-bold text-blue-800 text-right">{{ pit38.cryptoTax|number_format(2, ',', ' ') }} PLN</dd>
                    </div>
                </dl>
            </div>
        </section>

        {# Total tax #}
        <section class="bg-blue-600 rounded-lg p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-blue-100 text-sm font-medium">Laczny podatek do zaplaty</p>
                    <p class="text-xs text-blue-200 mt-0.5">Equity + Dywidendy + Krypto</p>
                </div>
                <p class="text-3xl font-bold text-white">{{ pit38.totalTax|number_format(2, ',', ' ') }} <span class="text-lg font-normal text-blue-200">PLN</span></p>
            </div>
        </section>

        {# Actions #}
        <div class="flex flex-col sm:flex-row gap-3">
            <a href="{{ path('declaration_export_xml', {taxYear: pit38.taxYear}) }}"
               class="flex-1 inline-flex items-center justify-center gap-2 rounded-md bg-blue-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                </svg>
                Eksportuj XML (e-Deklaracje)
            </a>
            <a href="{{ path('declaration_export_pdf', {taxYear: pit38.taxYear}) }}"
               class="flex-1 inline-flex items-center justify-center gap-2 rounded-md border border-gray-300 bg-white px-4 py-2.5 text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                Eksportuj PDF (audit trail)
            </a>
        </div>
    </div>

    {% include 'declaration/_disclaimer.html.twig' %}
</div>
{% endblock %}
