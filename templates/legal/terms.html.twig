{% extends 'base_public.html.twig' %}

{% block title %}Regulamin — TaxPilot{% endblock %}
{% block meta_description %}Regulamin swiadczenia uslug droga elektroniczna serwisu TaxPilot.{% endblock %}
{% block robots %}noindex, follow{% endblock %}

{% block body %}
<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-3xl font-bold text-gray-900 mb-8">Regulamin</h1>

    <div class="prose prose-gray max-w-none">
        <p class="text-gray-700 mb-6">
            Dokument w przygotowaniu. Niniejszy serwis swiadczy uslugi droga elektroniczna zgodnie z przepisami prawa polskiego.
        </p>

        <p class="text-gray-700 mb-6">
            Administratorem danych jest operator serwisu TaxPilot.
        </p>

        <p class="text-gray-700">
            Kontakt: <a href="mailto:kontakt@taxpilot.pl" class="text-blue-600 hover:text-blue-800">kontakt@taxpilot.pl</a>
        </p>
    </div>
</div>
{% endblock %}
