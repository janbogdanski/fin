{% extends 'base.html.twig' %}

{% block title %}Dashboard - TaxPilot{% endblock %}

{% block body %}
<div>
    {# Year selector + page heading #}
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <h1 class="text-2xl font-bold text-gray-900">Podsumowanie podatkowe</h1>
        <div data-controller="year-selector">
            <label for="tax-year" class="sr-only">Rok podatkowy</label>
            <select id="tax-year"
                    data-year-selector-target="select"
                    data-action="change->year-selector#change"
                    class="block w-full sm:w-auto rounded-md border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-blue-600">
                {% for year in availableYears %}
                    <option value="{{ year }}" {{ year == summary.taxYear ? 'selected' : '' }}>
                        Rok {{ year }}
                    </option>
                {% endfor %}
            </select>
        </div>
    </div>

    {# Summary cards #}
    <turbo-frame id="dashboard-summary">
        {% set totalProceeds = summary.equityProceeds|number_format(2, ',', ' ') %}
        {% set totalCosts = summary.equityCostBasis|number_format(2, ',', ' ') %}
        {% set totalGainLoss = summary.equityGainLoss|number_format(2, ',', ' ') %}
        {% set isProfit = summary.equityGainLoss|number_format(2) > 0 %}

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
                <p class="text-xs text-gray-500 uppercase tracking-wide font-medium mb-1">Przychod</p>
                <p class="text-2xl font-bold text-gray-900">{{ totalProceeds }} <span class="text-sm font-normal text-gray-500">PLN</span></p>
            </div>
            <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
                <p class="text-xs text-gray-500 uppercase tracking-wide font-medium mb-1">Koszty uzyskania</p>
                <p class="text-2xl font-bold text-gray-900">{{ totalCosts }} <span class="text-sm font-normal text-gray-500">PLN</span></p>
            </div>
            <div class="bg-white rounded-lg border {{ isProfit ? 'border-green-200 bg-green-50' : 'border-red-200 bg-red-50' }} p-5 shadow-sm">
                <p class="text-xs {{ isProfit ? 'text-green-600' : 'text-red-600' }} uppercase tracking-wide font-medium mb-1">
                    {{ isProfit ? 'Zysk' : 'Strata' }}
                </p>
                <p class="text-2xl font-bold {{ isProfit ? 'text-green-700' : 'text-red-700' }}">
                    {{ totalGainLoss }} <span class="text-sm font-normal {{ isProfit ? 'text-green-500' : 'text-red-500' }}">PLN</span>
                </p>
            </div>
            <div class="bg-white rounded-lg border border-blue-200 bg-blue-50 p-5 shadow-sm">
                <p class="text-xs text-blue-600 uppercase tracking-wide font-medium mb-1">Podatek do zaplaty</p>
                <p class="text-2xl font-bold text-blue-700">{{ summary.totalTaxDue|number_format(2, ',', ' ') }} <span class="text-sm font-normal text-blue-500">PLN</span></p>
            </div>
        </div>

        {# Breakdown per type #}
        <div class="mb-8">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">Rozliczenie wg kategorii</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                {# Equities / ETF #}
                <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-100 text-blue-600" aria-hidden="true">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
                            </svg>
                        </span>
                        <h3 class="text-sm font-semibold text-gray-900">Akcje / ETF</h3>
                    </div>
                    <dl class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Przychod</dt>
                            <dd class="font-medium text-gray-900">{{ summary.equityProceeds|number_format(2, ',', ' ') }} PLN</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Koszty</dt>
                            <dd class="font-medium text-gray-900">{{ summary.equityCostBasis|number_format(2, ',', ' ') }} PLN</dd>
                        </div>
                        <div class="flex justify-between border-t border-gray-100 pt-2">
                            <dt class="text-gray-700 font-medium">Podatek</dt>
                            <dd class="font-bold text-gray-900">{{ summary.equityTax|number_format(2, ',', ' ') }} PLN</dd>
                        </div>
                    </dl>
                </div>

                {# Dividends #}
                <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-purple-100 text-purple-600" aria-hidden="true">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </span>
                        <h3 class="text-sm font-semibold text-gray-900">Dywidendy</h3>
                    </div>
                    <dl class="space-y-2 text-sm">
                        {% set dividendGrossTotal = 0 %}
                        {% set dividendWhtTotal = 0 %}
                        {% for country in summary.dividendsByCountry %}
                            {% set dividendGrossTotal = dividendGrossTotal + country.grossDividendPLN %}
                            {% set dividendWhtTotal = dividendWhtTotal + country.whtPaidPLN %}
                        {% endfor %}
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Brutto</dt>
                            <dd class="font-medium text-gray-900">{{ dividendGrossTotal|number_format(2, ',', ' ') }} PLN</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-gray-500">WHT zaplacony</dt>
                            <dd class="font-medium text-gray-900">{{ dividendWhtTotal|number_format(2, ',', ' ') }} PLN</dd>
                        </div>
                        <div class="flex justify-between border-t border-gray-100 pt-2">
                            <dt class="text-gray-700 font-medium">Doplata PL</dt>
                            <dd class="font-bold text-gray-900">{{ summary.dividendTotalTaxDue|number_format(2, ',', ' ') }} PLN</dd>
                        </div>
                    </dl>
                </div>

                {# Crypto #}
                <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
                    <div class="flex items-center gap-2 mb-3">
                        <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-amber-100 text-amber-600" aria-hidden="true">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                            </svg>
                        </span>
                        <h3 class="text-sm font-semibold text-gray-900">Kryptowaluty</h3>
                    </div>
                    <dl class="space-y-2 text-sm">
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Przychod</dt>
                            <dd class="font-medium text-gray-900">{{ summary.cryptoProceeds|number_format(2, ',', ' ') }} PLN</dd>
                        </div>
                        <div class="flex justify-between">
                            <dt class="text-gray-500">Koszty</dt>
                            <dd class="font-medium text-gray-900">{{ summary.cryptoCostBasis|number_format(2, ',', ' ') }} PLN</dd>
                        </div>
                        <div class="flex justify-between border-t border-gray-100 pt-2">
                            <dt class="text-gray-700 font-medium">Podatek</dt>
                            <dd class="font-bold text-gray-900">{{ summary.cryptoTax|number_format(2, ',', ' ') }} PLN</dd>
                        </div>
                    </dl>
                </div>
            </div>
        </div>

        {# Status + Actions #}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            {# Status #}
            <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
                <h2 class="text-sm font-semibold text-gray-900 mb-3">Status rozliczenia</h2>
                <div class="flex items-center gap-2 mb-4">
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">
                        <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
                        </svg>
                        Gotowe do eksportu
                    </span>
                </div>
                <ul class="space-y-2 text-sm text-gray-600">
                    <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                        Transakcje zaimportowane
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                        Kursy NBP pobrane
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                        FIFO matching wykonany
                    </li>
                    <li class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-500 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" /></svg>
                        Obliczenie podatku gotowe
                    </li>
                </ul>
            </div>

            {# Quick actions #}
            <div class="bg-white rounded-lg border border-gray-200 p-5 shadow-sm">
                <h2 class="text-sm font-semibold text-gray-900 mb-3">Akcje</h2>
                <div class="space-y-3">
                    <a href="{{ path('import_index') }}"
                       class="flex items-center gap-3 rounded-md border border-gray-200 px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                        <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                        </svg>
                        Import CSV
                    </a>
                    <a href="{{ path('declaration_preview', {taxYear: summary.taxYear}) }}"
                       class="flex items-center gap-3 rounded-md border border-gray-200 px-4 py-3 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                        <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                        </svg>
                        Podglad PIT-38
                    </a>
                    <a href="{{ path('declaration_export_xml', {taxYear: summary.taxYear}) }}"
                       class="flex items-center gap-3 rounded-md border border-blue-200 bg-blue-50 px-4 py-3 text-sm font-medium text-blue-700 hover:bg-blue-100 transition-colors">
                        <svg class="w-5 h-5 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                        </svg>
                        Eksportuj XML do e-Deklaracji
                    </a>
                </div>
            </div>
        </div>

        {# Detail links #}
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <a href="{{ path('dashboard_calculation', {taxYear: summary.taxYear}) }}"
               class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm hover:border-gray-300 hover:shadow transition-all group">
                <h3 class="text-sm font-semibold text-gray-900 group-hover:text-blue-600 transition-colors">Szczegoly transakcji</h3>
                <p class="text-xs text-gray-500 mt-1">Wszystkie transakcje z kursami NBP</p>
            </a>
            <a href="{{ path('dashboard_fifo', {taxYear: summary.taxYear}) }}"
               class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm hover:border-gray-300 hover:shadow transition-all group">
                <h3 class="text-sm font-semibold text-gray-900 group-hover:text-blue-600 transition-colors">FIFO matching</h3>
                <p class="text-xs text-gray-500 mt-1">Parowanie kupna i sprzedazy</p>
            </a>
            <a href="{{ path('dashboard_dividends', {taxYear: summary.taxYear}) }}"
               class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm hover:border-gray-300 hover:shadow transition-all group">
                <h3 class="text-sm font-semibold text-gray-900 group-hover:text-blue-600 transition-colors">Dywidendy wg kraju</h3>
                <p class="text-xs text-gray-500 mt-1">WHT i doplata podatku per kraj</p>
            </a>
        </div>
    </turbo-frame>

    {% include 'declaration/_disclaimer.html.twig' %}
</div>
{% endblock %}
