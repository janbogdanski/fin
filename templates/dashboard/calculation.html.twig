{% extends 'base.html.twig' %}

{% block title %}Transakcje {{ summary.taxYear }} - TaxPilot{% endblock %}

{% block body %}
<div>
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <div>
            <a href="{{ path('dashboard_index') }}" class="text-sm text-blue-600 hover:text-blue-800 font-medium">&larr; Dashboard</a>
            <h1 class="text-2xl font-bold text-gray-900 mt-1">Szczegoly transakcji {{ summary.taxYear }}</h1>
            <p class="text-sm text-gray-600 mt-1">Kazdy wiersz pokazuje jedno sparowanie FIFO: oryginalne ceny BUY/SELL, waluty z eksportu brokera, kursy NBP i wynik w PLN.</p>
        </div>
    </div>

    {% if isEmpty is defined and isEmpty %}
    <div class="bg-white rounded-lg border border-gray-200 p-8 text-center mb-8">
        <h2 class="text-lg font-semibold text-gray-700 mb-2">Brak danych</h2>
        <p class="text-sm text-gray-500 mb-4">Wgraj plik brokera z transakcjami aby zobaczyc szczegoly.</p>
        <a href="{{ path('import_index') }}" class="inline-flex items-center gap-2 rounded-md bg-blue-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-blue-700 transition-colors">Importuj pliki</a>
    </div>
    {% endif %}

    <div class="grid gap-4 sm:grid-cols-3 mb-6">
        <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
            <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Przychod</p>
            <p class="mt-2 text-2xl font-semibold text-gray-900">{{ summary.equityProceeds|number_format(2, ',', ' ') }} PLN</p>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
            <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Koszt + prowizje</p>
            <p class="mt-2 text-2xl font-semibold text-gray-900">{{ costsWithCommissions|number_format(2, ',', ' ') }} PLN</p>
        </div>
        <div class="bg-white rounded-lg border border-gray-200 p-4 shadow-sm">
            <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Wynik</p>
            <p class="mt-2 text-2xl font-semibold {{ summary.equityGainLoss > 0 ? 'text-green-600' : (summary.equityGainLoss < 0 ? 'text-red-600' : 'text-gray-900') }}">{{ summary.equityGainLoss|number_format(2, ',', ' ') }} PLN</p>
        </div>
    </div>

    <div class="bg-white rounded-lg border border-gray-200 p-4 mb-6 shadow-sm" data-controller="filter">
        <div class="flex flex-col sm:flex-row gap-3">
            <div>
                <label for="filter-broker" class="block text-xs font-medium text-gray-500 mb-1">Broker</label>
                <select id="filter-broker"
                        data-filter-target="broker"
                        data-action="change->filter#apply"
                        class="block w-full sm:w-40 rounded-md border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-blue-600">
                    <option value="">Wszystkie</option>
                    {% for broker in brokers %}
                        <option value="{{ broker }}">{{ broker }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label for="filter-instrument" class="block text-xs font-medium text-gray-500 mb-1">Instrument</label>
                <input type="text"
                       id="filter-instrument"
                       placeholder="np. AAPL lub ISIN"
                       data-filter-target="instrument"
                       data-action="input->filter#apply"
                       class="block w-full sm:w-40 rounded-md border-gray-300 bg-white px-3 py-1.5 text-sm text-gray-700 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-blue-600 placeholder:text-gray-400">
            </div>
        </div>
    </div>

    {# Transactions table #}
    <div class="bg-white border border-gray-200 rounded-lg overflow-x-auto shadow-sm" data-controller="table-sort">
        <table class="min-w-full text-sm" data-filter-target="table">
            <thead>
                <tr class="bg-gray-50 text-gray-600 border-b border-gray-200">
                    <th class="px-4 py-3 text-left font-medium cursor-pointer select-none hover:text-gray-900"
                        data-action="click->table-sort#sort" data-table-sort-key-param="sortDate">
                        Data sprzedazy
                        <span class="inline-block ml-1 text-gray-400" aria-hidden="true">&udarr;</span>
                    </th>
                    <th class="px-4 py-3 text-left font-medium cursor-pointer select-none hover:text-gray-900"
                        data-action="click->table-sort#sort" data-table-sort-key-param="instrument">
                        Instrument
                        <span class="inline-block ml-1 text-gray-400" aria-hidden="true">&udarr;</span>
                    </th>
                    <th class="px-4 py-3 text-left font-medium">Kupno</th>
                    <th class="px-4 py-3 text-left font-medium">Sprzedaz</th>
                    <th class="px-4 py-3 text-right font-medium cursor-pointer select-none hover:text-gray-900" data-action="click->table-sort#sort" data-table-sort-key-param="quantity">
                        Ilosc
                        <span class="inline-block ml-1 text-gray-400" aria-hidden="true">&udarr;</span>
                    </th>
                    <th class="px-4 py-3 text-right font-medium">Koszt PLN</th>
                    <th class="px-4 py-3 text-right font-medium">Przychod PLN</th>
                    <th class="px-4 py-3 text-right font-medium cursor-pointer select-none hover:text-gray-900" data-action="click->table-sort#sort" data-table-sort-key-param="gainloss">
                        Zysk/Strata PLN
                        <span class="inline-block ml-1 text-gray-400" aria-hidden="true">&udarr;</span>
                    </th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-100" data-table-sort-target="body">
                {% for tx in transactions %}
                <tr class="hover:bg-gray-50 transition-colors"
                    data-broker="{{ tx.broker }}"
                    data-instrument="{{ tx.instrument }}"
                    data-type="{{ tx.type }}"
                    data-sort-date="{{ tx.sortDate }}"
                    data-quantity="{{ tx.quantity }}"
                    data-gainloss="{{ tx.gainLossPLN ?? '0' }}">
                    <td class="px-4 py-2.5 text-gray-900 font-mono text-xs">{{ tx.sellDate }}</td>
                    <td class="px-4 py-2.5 text-gray-900">
                        <div class="font-medium">{{ tx.symbol }}</div>
                        <div class="font-mono text-xs text-gray-500">{{ tx.isin }}</div>
                    </td>
                    <td class="px-4 py-2.5 text-xs text-gray-700">
                        <div class="font-mono text-gray-900">{{ tx.buyDate }}</div>
                        <div>{{ tx.buyBroker }}</div>
                        <div class="font-mono text-gray-900">{{ tx.buyPriceOriginal ?: 'brak danych' }} {{ tx.buyCurrency ?: '' }}</div>
                        <div class="font-mono text-gray-500">NBP {{ tx.buyNbpRate }}</div>
                    </td>
                    <td class="px-4 py-2.5 text-xs text-gray-700">
                        <div class="font-mono text-gray-900">{{ tx.sellDate }}</div>
                        <div>{{ tx.sellBroker }}</div>
                        <div class="font-mono text-gray-900">{{ tx.sellPriceOriginal ?: 'brak danych' }} {{ tx.sellCurrency ?: '' }}</div>
                        <div class="font-mono text-gray-500">NBP {{ tx.sellNbpRate }}</div>
                    </td>
                    <td class="px-4 py-2.5 text-right text-gray-900 font-mono text-xs">{{ tx.quantity }}</td>
                    <td class="px-4 py-2.5 text-right text-gray-900 font-mono text-xs">{{ tx.costBasisPLN|number_format(2, ',', ' ') }}</td>
                    <td class="px-4 py-2.5 text-right text-gray-900 font-mono text-xs">{{ tx.proceedsPLN|number_format(2, ',', ' ') }}</td>
                    <td class="px-4 py-2.5 text-right font-mono text-xs font-medium {{ tx.gainLossPLN is not null and tx.gainLossPLN > 0 ? 'text-green-600' : (tx.gainLossPLN is not null and tx.gainLossPLN < 0 ? 'text-red-600' : 'text-gray-400') }}">
                        {% if tx.gainLossPLN is not null %}
                            {{ tx.gainLossPLN|number_format(2, ',', ' ') }}
                        {% else %}
                            &mdash;
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% include 'declaration/_disclaimer.html.twig' %}
</div>
{% endblock %}
