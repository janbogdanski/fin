###> symfony/framework-bundle ###
APP_ENV=dev
# SECURITY: Override APP_SECRET in .env.local with a cryptographically random 32+ char string
# Generate with: php -r "echo bin2hex(random_bytes(16));"
APP_SECRET=CHANGE_ME_NOT_A_REAL_SECRET
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="postgresql://taxpilot:taxpilot@postgres:5432/taxpilot?serverVersion=17&charset=utf8"
###< doctrine/doctrine-bundle ###

###> redis ###
# SECURITY: Override REDIS_PASSWORD in .env.local with a strong password
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=redis_dev_password
# Production v1 (MyDevil): Redis is local (no TLS needed) — see ADR-022
# REDIS_URL=redis://:STRONG_PASSWORD@127.0.0.1:DEVIL_REDIS_PORT
# Production v2 (AWS ElastiCache): use rediss:// scheme for TLS — see ADR-022
# REDIS_URL=rediss://:AUTH_TOKEN@ELASTICACHE_ENDPOINT:6380
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
###< redis ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailpit:1025
MAILER_FROM=noreply@taxpilot.pl
###< symfony/mailer ###

###> app/security ###
# SECURITY: Override ENCRYPTION_KEY in .env.local with a 32-byte base64-encoded key
# Generate with: php -r "echo base64_encode(random_bytes(32));"
ENCRYPTION_KEY=CHANGE_ME_NOT_A_REAL_KEY
# SECURITY: Override NIP_HMAC_KEY in .env.local with a 32-byte base64-encoded key
# Generate with: php -r "echo base64_encode(random_bytes(32));"
NIP_HMAC_KEY=CHANGE_ME_NOT_A_REAL_KEY
###< app/security ###

###> app/billing ###
# SECURITY: Override in .env.local with real Stripe keys
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
###< app/billing ###
