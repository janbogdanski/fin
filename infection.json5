{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": [
            "src"
        ],
        "excludes": [
            "TaxCalc/Infrastructure",
            "TaxCalc/Application/Service/ImportDividendService.php",
            "TaxCalc/Application/Service/ImportToLedgerService.php",
            "TaxCalc/Application/Service/AnnualTaxCalculationService.php",
            "TaxCalc/Application/Command",
            "Identity/Infrastructure",
            "Identity/Application/Command",
            "Identity/Application/Exception",
            "Billing/Infrastructure",
            "BrokerImport/Infrastructure",
            "BrokerImport/Application",
            "Shared/Infrastructure",
            "ExchangeRate/Infrastructure",
            "Declaration/Infrastructure",
            "Declaration/Application",
            "Audit",
            "Kernel.php"
        ]
    },
    "phpUnit": {
        "configDir": ".",
        "customPath": "vendor/bin/phpunit"
    },
    "testFrameworkOptions": "--testsuite=unit",
    "minMsi": 70,
    "minCoveredMsi": 82,
    "mutators": {
        "@default": true
    }
}