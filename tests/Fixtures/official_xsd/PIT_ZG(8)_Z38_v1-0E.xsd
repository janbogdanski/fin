<?xml version="1.0" encoding="utf-8"?>
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:etd="http://crd.gov.pl/xml/schematy/dziedzinowe/mf/2022/09/13/eD/DefinicjeTypy/" xmlns:kk="http://crd.gov.pl/xml/schematy/dziedzinowe/mf/2023/09/06/eD/KodyKrajow/" xmlns:zg38="http://crd.gov.pl/xml/schematy/dziedzinowe/mf/2023/10/18/eD/PITZGZ38/" targetNamespace="http://crd.gov.pl/xml/schematy/dziedzinowe/mf/2023/10/18/eD/PITZGZ38/" elementFormDefault="qualified" attributeFormDefault="unqualified" xml:lang="pl">
	<xsd:import namespace="http://crd.gov.pl/xml/schematy/dziedzinowe/mf/2023/09/06/eD/KodyKrajow/" schemaLocation="KodyKrajow_v13-0E.xsd"/>
	<xsd:import namespace="http://crd.gov.pl/xml/schematy/dziedzinowe/mf/2022/09/13/eD/DefinicjeTypy/" schemaLocation="StrukturyDanych_v12-0E.xsd"/>
	<!--Załącznik do zeznania PIT-38.-->
	<!-- -->
	<!--Wypełniają podatnicy, którzy uzyskali dochody/przychody opodatkowane zgodnie z art. 27 ust. 8, 9, 9a, art. 30b ust. 5a, 5b, 5e, 5f, art. 30c ust. 4, 5 lub art. 30e ust. 8 i 9 ustawy. Załącznik PIT/ZG składa się odrębnie dla każdego państwa uzyskania dochodu/przychodu.-->
	<xsd:complexType name="TNaglowek_PIT_ZG">
		<xsd:annotation>
			<xsd:documentation>Nagłówek deklaracji</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="KodFormularza">
				<xsd:complexType>
					<xsd:simpleContent>
						<xsd:extension base="zg38:TKodFormularza_ZG">
							<xsd:attribute name="kodSystemowy" type="xsd:string" use="required" fixed="PIT/ZG (8)"/>
							<xsd:attribute name="wersjaSchemy" type="xsd:string" use="required" fixed="1-0E"/>
						</xsd:extension>
					</xsd:simpleContent>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="WariantFormularza">
				<xsd:simpleType>
					<xsd:restriction base="xsd:byte">
						<xsd:enumeration value="8"/>
					</xsd:restriction>
				</xsd:simpleType>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:simpleType name="TKodFormularza_ZG">
		<xsd:annotation>
			<xsd:documentation>Symbol wzoru formularza</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="PIT/ZG"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="TKodKrajuWydania">
		<xsd:annotation>
			<xsd:documentation>Kod kraju wydania numeru identyfikacyjnego</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="kk:TKodKraju">
			<xsd:pattern value="P[A-KM-Z]"/>
			<xsd:pattern value="[A-OQ-Z][A-Z]"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:element name="Zalacznik_PIT_ZG">
		<xsd:annotation>
			<xsd:documentation>INFORMACJA O WYSOKOŚCI DOCHODÓW / PRZYCHODÓW Z ZAGRANICY I ZAPŁACONYM PODATKU za rok podatkowy</xsd:documentation>
		</xsd:annotation>
		<xsd:complexType>
			<xsd:sequence>
				<xsd:element name="Naglowek" type="zg38:TNaglowek_PIT_ZG"/>
				<xsd:element name="PozycjeSzczegolowe">
					<xsd:annotation>
						<xsd:documentation>Dochody i podatek rozliczane w zeznaniu podatkowym PIT-38</xsd:documentation>
					</xsd:annotation>
					<xsd:complexType>
						<xsd:sequence>
							<xsd:element name="P_7" type="zg38:TKodKrajuWydania">
								<xsd:annotation>
									<xsd:documentation>Kod kraju</xsd:documentation>
								</xsd:annotation>
							</xsd:element>
							<xsd:sequence minOccurs="0">
								<xsd:element name="P_29" type="etd:TKwota2Nieujemna" default="0">
									<xsd:annotation>
										<xsd:documentation>Dochód, o którym mowa w art. 30b ust. 5a i 5b ustawy</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="P_30" type="etd:TKwota2Nieujemna">
									<xsd:annotation>
										<xsd:documentation>Podatek zapłacony za granicą od dochodów z poz. 32</xsd:documentation>
									</xsd:annotation>
									<!--Podatek zapłacony za granicą, bez uwzględnienia limitu, o którym mowa w art. 27 ust. 9 i 9a, art. 30b ust. 5a, 5b, 5e i 5f, art. 30c ust. 4 i 5, art. 30e ust. 8 i 9 ustawy.-->
								</xsd:element>
							</xsd:sequence>
							<xsd:sequence minOccurs="0">
								<xsd:element name="P_31" type="etd:TKwota2Nieujemna">
									<xsd:annotation>
										<xsd:documentation>Dochód, o którym mowa w art. 30b ust. 5e i 5f ustawy</xsd:documentation>
									</xsd:annotation>
								</xsd:element>
								<xsd:element name="P_32" type="etd:TKwota2Nieujemna">
									<xsd:annotation>
										<xsd:documentation>Podatek zapłacony za granicą od dochodów z poz. 34</xsd:documentation>
									</xsd:annotation>
									<!--Podatek zapłacony za granicą, bez uwzględnienia limitu, o którym mowa w art. 27 ust. 9 i 9a, art. 30b ust. 5a, 5b, 5e i 5f, art. 30c ust. 4 i 5 lub art. 30e ust. 8 i 9 ustawy.-->
								</xsd:element>
							</xsd:sequence>
						</xsd:sequence>
					</xsd:complexType>
				</xsd:element>
			</xsd:sequence>
		</xsd:complexType>
	</xsd:element>
</xsd:schema>
