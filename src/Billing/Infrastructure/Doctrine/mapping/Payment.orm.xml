<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                  https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Billing\Domain\Model\Payment" table="payments">
        <id name="id" type="guid" column="id">
            <generator strategy="NONE"/>
        </id>

        <field name="userId" type="user_id" column="user_id" nullable="false"/>
        <field name="providerSessionId" type="string" column="stripe_session_id" length="255" nullable="false" unique="true"/>
        <field name="providerTransactionId" type="string" column="stripe_payment_intent_id" length="255" nullable="true"/>
        <field name="productCode" type="string" column="product_code" length="20" nullable="false" enumType="App\Billing\Domain\ValueObject\ProductCode"/>
        <field name="amountCents" type="integer" column="amount_cents" nullable="false"/>
        <field name="currency" type="string" column="currency" length="3" nullable="false"/>
        <field name="status" type="string" column="status" length="20" nullable="false" enumType="App\Billing\Domain\ValueObject\PaymentStatus"/>
        <field name="createdAt" type="datetime_immutable" column="created_at" nullable="false"/>
    </entity>

</doctrine-mapping>
